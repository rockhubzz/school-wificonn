# Backend URL (the server's IP on VLAN 10)
PORTAL_PUBLIC_URL="http://192.168.10.10"

# Prisma / SQLite
DATABASE_URL="file:./prod.db"

# MikroTik RouterOS API
MIKROTIK_HOST="192.168.10.1"
MIKROTIK_PORT="8728"
MIKROTIK_API_USER="portal-api"
MIKROTIK_API_PASS="CHANGE_ME"

# Timeouts
MIKROTIK_CONNECT_TIMEOUT_MS="8000"
MIKROTIK_COMMAND_TIMEOUT_MS="12000"
MIKROTIK_SOCKET_TIMEOUT_SEC="10"
MIKROTIK_MAX_RETRIES="2"
MIKROTIK_CIRCUIT_THRESHOLD="5"
MIKROTIK_CIRCUIT_COOLDOWN_MS="30000"

# Hotspot
MIKROTIK_HOTSPOT_USER_PROFILE="student-profile"
HOTSPOT_GATEWAY_URL="http://192.168.30.1/status"

# Session (generate with: openssl rand -base64 48)
SESSION_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL"
SESSION_COOKIE_NAME="cp_admin"

NODE_ENV="production"
